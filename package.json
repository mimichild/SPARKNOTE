{
  "name": "sparknotes",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/jest-preset": "^0.85.3",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|zustand|uuid)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^expo-sqlite$": "<rootDir>/src/__mocks__/expo-sqlite.ts",
      "^expo-file-system$": "<rootDir>/src/__mocks__/expo-file-system.ts",
      "^@react-native-async-storage/async-storage$": "<rootDir>/src/__mocks__/async-storage.ts"
    },
    "testMatch": [
      "<rootDir>/src/__tests__/**/*.test.(ts|tsx)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/__mocks__/**",
      "!src/__tests__/**"
    ]
  }
}
